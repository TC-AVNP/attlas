{$CADDY_DOMAIN} {
	@notlogin not path /login /logout
	forward_auth @notlogin localhost:3000 {
		uri /api/auth/verify
		copy_headers Location
	}

	import /etc/caddy/conf.d/*.caddy

	# Default backend — must use reverse_proxy directly, not inside handle
	# so imported handle/handle_path blocks take priority
	reverse_proxy localhost:3000
}
