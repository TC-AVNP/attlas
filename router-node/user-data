#cloud-config

hostname: pi-router
manage_etc_hosts: true
ssh_pwauth: true

users:
  - name: commonlisp
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    passwd: $6$z1IMtZUaoHTEMejl$R8UVDcT0IRATQuaxQUe9SnCtGjQj0Z32LCNmhclkECsob6eQlEh1l1/kkXwo4SXYwCIe8idKWLgPKue0coB6A.

write_files:
  - path: /opt/router/entrypoint.sh
    permissions: '0755'
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      BOOTSTRAP_URL="https://homelab.attlas.uk"
      LOG="/var/log/router-bootstrap.log"
      MARKER="/etc/router/.provisioned"
      CONFIG="/etc/router/config.json"

      log() { echo "[$(date -Iseconds)] $*" | tee -a "$LOG"; }

      if [[ -f "$MARKER" ]]; then
        log "Already provisioned, skipping"
        exit 0
      fi

      mkdir -p /etc/router

      # Read token baked into the image by build-image.sh
      if [[ ! -f /etc/image-token ]]; then
        log "FATAL: /etc/image-token not found — image was not built with a token"
        exit 1
      fi
      TOKEN=$(cat /etc/image-token)

      # Collect hardware info
      MAC=""
      for iface in eth0 end0 wlan0; do
        if [[ -f "/sys/class/net/${iface}/address" ]]; then
          MAC=$(cat "/sys/class/net/${iface}/address")
          break
        fi
      done
      if [[ -z "$MAC" ]]; then
        log "FATAL: no MAC address found"
        exit 1
      fi

      MODEL=$(tr -d '\0' < /proc/device-tree/model 2>/dev/null || echo "unknown")
      CPU_CORES=$(nproc)
      MEMORY_MB=$(free -m | awk '/Mem:/{print $2}')
      LAN_IP=$(ip -4 addr show eth0 2>/dev/null | grep -oP '(?<=inet )\d+\.\d+\.\d+\.\d+' || echo "")

      log "Hardware: $MODEL, $CPU_CORES cores, ${MEMORY_MB}MB, MAC=$MAC"

      PAYLOAD=$(jq -n \
        --arg mac "$MAC" \
        --arg host "pi-router" \
        --arg model "$MODEL" \
        --argjson cpu "$CPU_CORES" \
        --argjson mem "$MEMORY_MB" \
        --arg ip "$LAN_IP" \
        '{mac_address: $mac, hostname: $host, model: $model, cpu_cores: $cpu, memory_mb: $mem, lan_ip: $ip}')

      # Register with backoff
      BACKOFF=5
      MAX_BACKOFF=300
      log "Registering with $BOOTSTRAP_URL..."
      while true; do
        HTTP_CODE=$(curl -sf -o /tmp/reg.json -w "%{http_code}" \
          --connect-timeout 10 --max-time 30 \
          -X POST "${BOOTSTRAP_URL}/api/register/router" \
          -H "Content-Type: application/json" \
          -H "X-Image-Token: ${TOKEN}" \
          -d "$PAYLOAD" 2>/dev/null) || HTTP_CODE="000"

        if [[ "$HTTP_CODE" == "201" ]]; then break; fi
        if [[ "$HTTP_CODE" == "403" ]]; then
          log "Token revoked or wrong type — cannot register"
          exit 1
        fi
        log "HTTP $HTTP_CODE, retrying in ${BACKOFF}s..."
        sleep $BACKOFF
        BACKOFF=$((BACKOFF * 2))
        if [[ $BACKOFF -gt $MAX_BACKOFF ]]; then BACKOFF=$MAX_BACKOFF; fi
      done

      mv /tmp/reg.json "$CONFIG"
      log "Registered: $(python3 -c "import json; r=json.load(open('$CONFIG')); print(f'node_id={r[\"node_id\"]} label={r[\"label\"]}')")"

      # Extract and run playbook
      python3 -c "
      import json, base64
      with open('$CONFIG') as f:
          r = json.load(f)
      with open('/tmp/playbook.tar.gz', 'wb') as f:
          f.write(base64.b64decode(r['playbook']))
      "
      mkdir -p /opt/provision
      tar -xzf /tmp/playbook.tar.gz -C /opt/provision/
      rm -f /tmp/playbook.tar.gz

      log "Running ansible-playbook..."
      ansible-playbook \
        -i localhost, \
        --limit localhost \
        /opt/provision/playbook.yml \
        -e "@${CONFIG}" \
        2>&1 | tee -a "$LOG"

      if [[ ${PIPESTATUS[0]} -eq 0 ]]; then
        log "Provisioning complete!"
        touch "$MARKER"
      else
        log "ERROR: ansible-playbook failed"
        exit 1
      fi

  - path: /etc/systemd/system/router-provision.service
    content: |
      [Unit]
      Description=Router node provisioning
      After=network-online.target
      Wants=network-online.target
      ConditionPathExists=!/etc/router/.provisioned
      [Service]
      Type=oneshot
      ExecStart=/opt/router/entrypoint.sh
      RemainAfterExit=true
      TimeoutStartSec=900
      [Install]
      WantedBy=multi-user.target

runcmd:
  - mkdir -p /opt/router
  - systemctl daemon-reload
  - systemctl enable router-provision.service
  - systemctl start router-provision.service
